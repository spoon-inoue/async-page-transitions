---
interface Props {
  path: string
}

const { path } = Astro.props

const src = `${import.meta.env.BASE_URL}${path}`
---

<img src={src} alt="" />

<style lang="scss" is:global>
  img {
    margin-top: 30px;
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: 5px;
  }
</style>

---
import '@styles/imports.scss'
import Header from '@components/common/Header.astro'

interface Props {
  namespace: string
}

const { namespace } = Astro.props
---

<!doctype html>
<html lang="en" data-overlayscrollbars-initialize>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="meta/favicon.svg" />
    <link rel="icon" href="meta/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <slot name="title" />
  </head>
  <body>
    <Header />
    <div data-transition="wrapper" data-overlayscrollbars-initialize>
      <main data-transition="container" data-namespace={namespace}>
        <slot />
      </main>
    </div>
  </body>
</html>

<script src="../scripts/entry.ts"></script>

<style lang="scss" is:global>
  @use '/src/styles/functions/color.scss';
  @use '/src/styles/mixins/media.scss' as *;
  @use '/src/styles/mixins/font.scss';

  html {
    background: color.$light;
    color: color.$dark;
    @include font.inconsolata;
    font-size: 17px;
    scrollbar-gutter: auto !important;
    @include sp {
      font-size: 15px;
    }
  }

  div[data-transition='wrapper'] {
    position: relative;
    background: color.$dark;
  }

  main {
    position: relative;
    background: color.$light;
    padding: 80px max(100px, calc((100vw - 1200px) * 0.5));
    @include sp {
      padding: 80px 30px;
    }

    &.transition {
      position: absolute;
      top: 0;
      clip-path: inset(var(--offset-y, 0px) 0 calc(100% - 100vh - var(--offset-y, 0px)) 0);
      transform-origin: 50% calc((100% - 100vh * 2) + var(--offset-y, 0px));
      will-change: scale;

      &::before {
        content: '';
        position: absolute;
        left: 0;
        top: 0;
        user-select: none;
        pointer-events: none;
        width: 100%;
        height: 100%;
        background: #000;
        background: color-mix(in srgb, color.$dark, transparent var(--transparent, 100%));
      }
    }
  }

  h1,
  h2 {
    font-weight: inherit;
    font-size: inherit;
  }

  a {
    color: inherit;
    text-decoration: unset;
  }
</style>
